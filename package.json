{
  "name": "addressium",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source, self-hostable replacement for the email capabilities of Amazon Pinpoint.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*",
    "infra/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build --dry",
    "clean": "tsc --build --clean",
    "test": "tsc --build && node --test packages/domain/dist/test/*.test.js packages/integration-tests/dist/test/*.test.js",
    "deploy": "npm --workspace @addressium/infra-cdk run deploy"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
