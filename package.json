{
  "name": "addressium",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source, self-hostable replacement for the email capabilities of Amazon Pinpoint.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*",
    "infra/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build --dry",
    "clean": "tsc --build --clean",
    "test": "tsc --build && node --test packages/domain/dist/test/*.test.js packages/integration-tests/dist/test/*.test.js",
    "test:web": "vitest run",
    "deploy": "npm --workspace @addressium/infra-cdk run deploy"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.43",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
